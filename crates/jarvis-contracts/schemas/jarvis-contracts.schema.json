        "provider.unavailable",
        "provider.quota_exhausted",
        "policy.denied",
        "grant.expired",
        "grant.args_mismatch",
        "grant.consumed",
        "tool.timeout",
        "tool.result_invalid",
        "artifact.too_large",
        "degraded.queued"
      ],
      "type": "string"
    },
    "EventEnvelope": {
      "properties": {
        "channel": {
          "$ref": "#/definitions/Channel"
        },
        "occurredAt": {
          "description": "RFC 3339 timestamp of the domain occurrence.",
          "type": "string"
        },
        "payload": true,
        "resourceVersion": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "seq": {
