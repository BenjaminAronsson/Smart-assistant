        "id": {
          "$ref": "#/definitions/UlidString"
        },
        "status": {
          "$ref": "#/definitions/SessionStatus"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "description": "RFC 3339.",
          "type": "string"
        }
      },
