        "code": {
          "$ref": "#/definitions/ErrorCode"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "instance": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "description": "Problem type URI; `about:blank` when the code says it all.",
          "type": "string"
        }
      },
      "required": [
        "type",
        "title",
        "status",
        "code"
      ],
      "type": "object"
