      "description": "ULID: 26 chars of uppercase Crockford base32",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    }
  },
  "description": "Jarvis wire contract v1 (generated — do not edit)",
  "title": "jarvis-contracts"
