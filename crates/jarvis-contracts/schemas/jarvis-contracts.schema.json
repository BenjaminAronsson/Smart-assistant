{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AdapterHealth": {
      "properties": {
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/definitions/AdapterState"
        }
      },
      "required": [
        "state"
      ],
      "type": "object"
    },
    "AdapterState": {
      "description": "`disabled` = present in config but switched off (e.g. voice before M5).",
      "enum": [
        "up",
        "down",
        "disabled"
      ],
      "type": "string"
    },
    "ApprovalCardDto": {
      "description": "What a human is asked to approve (docs/06 §3). Carries the exact effect and\nthe real proposed arguments so the approval binds precisely what is shown.",
      "properties": {
        "approvalId": {
          "$ref": "#/definitions/UlidString",
          "description": "The pending approval this card asks about; echoed back on the decision."
        },
        "egress": {
          "$ref": "#/definitions/DataEgressDto"
        },
        "exactEffect": {
          "description": "A human-readable rendering of exactly what will execute — the real target\nand payload, never a summary (docs/06 §3). Snapshot-tested.",
          "type": "string"
        },
        "proposedArguments": true,
        "reversible": {
          "description": "Whether the tool registered a compensating undo (docs/06 §4).",
          "type": "boolean"
        },
        "risk": {
          "$ref": "#/definitions/RiskLevelDto"
        },
        "runId": {
          "$ref": "#/definitions/UlidString"
        },
        "toolId": {
          "description": "The namespaced tool identifier (e.g. `message.send`).",
          "type": "string"
        }
      },
      "required": [
        "approvalId",
        "runId",
        "toolId",
        "exactEffect",
        "proposedArguments",
        "risk",
        "reversible",
        "egress"
      ],
      "type": "object"
    },
    "ApprovalDecision": {
      "description": "The verb a human answers a card with (docs/05 §4). Distinct from\n[`ApprovalResolutionDto`]'s past-tense outcome: this is the request input.",
      "enum": [
        "approve",
        "deny"
      ],
      "type": "string"
    },
    "ApprovalDecisionDto": {
      "description": "Body of `POST /api/v1/runs/{id}/approvals/{approval_id}` (docs/05 §4). On\n`approve`, `editedArguments` (when present) replaces the proposed arguments —\nthe grant binds the edited set, so executing the original would fail\nvalidation (invalidation by hash, not a flag; docs/06 §4). Ignored on `deny`.",
      "properties": {
        "decision": {
          "$ref": "#/definitions/ApprovalDecision"
        },
        "editedArguments": true
      },
      "required": [
        "decision"
      ],
      "type": "object"
    },
    "ApprovalResolutionDto": {
      "description": "How an approval was resolved (docs/05 §3), carried by the `approval.resolved`\nevent. Past tense to the [`ApprovalDecision`] request verb.",
      "enum": [
        "approved",
        "denied"
      ],
      "type": "string"
    },
    "ArtifactKindDto": {
      "description": "The logical kind of an artifact, selecting its renderer (docs/02 §6).",
      "enum": [
        "markdown_html",
        "code_text",
        "image",
        "chart",
        "bundle"
      ],
      "type": "string"
    },
    "ArtifactManifestDto": {
      "description": "One immutable artifact-version manifest (docs/02 §6, docs/04 §4, FR-08).",
      "properties": {
        "build": {
          "$ref": "#/definitions/BuildProvenanceDto"
        },
        "capabilities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "createdByRun": {
          "$ref": "#/definitions/UlidString"
        },
        "id": {
          "$ref": "#/definitions/UlidString"
        },
        "kind": {
          "$ref": "#/definitions/ArtifactKindDto"
        },
        "mediaType": {
          "type": "string"
        },
        "renderer": {
          "description": "Versioned renderer id (docs/04 §4), derived from `kind`.",
          "type": "string"
        },
        "sensitivity": {
          "$ref": "#/definitions/ArtifactSensitivityDto"
        },
        "sha256": {
          "description": "Content address of the blob (lowercase hex sha256) — also the blob's\ndownload ETag.",
          "type": "string"
        },
        "sources": {
          "items": {
            "$ref": "#/definitions/ArtifactSourceDto"
          },
          "type": "array"
        },
        "version": {
          "description": "Monotonic version, 1-based.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "createdByRun",
        "sha256",
        "mediaType",
        "kind",
        "renderer",
        "sources",
        "sensitivity",
        "build",
        "capabilities"
      ],
      "type": "object"
    },
    "ArtifactSensitivityDto": {
      "description": "Sensitivity class of the artifact (NFR-02).",
      "enum": [
        "normal",
        "sensitive"
      ],
      "type": "string"
    },
    "ArtifactSourceDto": {
      "description": "One provenance source: what it is plus its reference (a ULID for\nmessage/run, a URL for web). The web shell renders these as a sources card\n(F3b.6), each with its own attribution (FR-27/ADR-017).",
      "properties": {
        "kind": {
          "$ref": "#/definitions/ArtifactSourceKindDto"
        },
        "reference": {
          "description": "The message/run ULID or the web URL, per `kind`.",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "reference"
      ],
      "type": "object"
    },
    "ArtifactSourceKindDto": {
      "description": "What kind of thing a provenance source refers to (docs/04 §4 `sources`).",
      "enum": [
        "message",
        "run",
        "web"
      ],
      "type": "string"
    },
    "ArtifactVersionsResponse": {
      "description": "`GET /api/v1/artifacts/{id}/versions` — every version of one artifact,\noldest first (docs/05 §1, FR-08).",
      "properties": {
        "artifactId": {
          "$ref": "#/definitions/UlidString"
        },
        "versions": {
          "items": {
            "$ref": "#/definitions/ArtifactManifestDto"
          },
          "type": "array"
        }
      },
      "required": [
        "artifactId",
        "versions"
      ],
      "type": "object"
    },
    "BuildNetworkDto": {
      "description": "The network policy under which the artifact was built (docs/04 §4).",
      "enum": [
        "disabled",
        "enabled"
      ],
      "type": "string"
    },
    "BuildProvenanceDto": {
      "description": "How the artifact was built (docs/04 §4 `build`). Carries only hashes and\nimage references — never secrets (invariant 5).",
      "properties": {
        "lockfileHash": {
          "type": [
            "string",
            "null"
          ]
        },
        "network": {
          "$ref": "#/definitions/BuildNetworkDto"
        },
        "workerImage": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "network"
      ],
      "type": "object"
    },
    "Channel": {
      "description": "One WebSocket replaces v1's three hubs; `channel` discriminates (docs/05 §1).",
      "enum": [
        "session",
        "display",
        "voice"
      ],
      "type": "string"
    },
    "ContentBlock": {
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "const": "text",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "type": "object"
        },
        {
          "description": "Forward-compatibility catch-all (docs/05 §5). Never produced by this\nversion's writers; only ever the result of reading a newer peer.",
          "properties": {
            "type": {
              "const": "unknown",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        }
      ]
    },
    "CreateSessionRequest": {
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "DataEgressDto": {
      "description": "Wire projection of [`jarvis_domain::policy::DataEgress`] (docs/06 §5): how far\nthe tool's data may travel, surfaced so the human approves egress knowingly.",
      "enum": [
        "none",
        "local",
        "external"
      ],
      "type": "string"
    },
    "DomainEvent": {
      "description": "Persisted, replayable events (docs/05 §3 \"persisted event categories\").\nEvery variant must be representable in the timeline snapshot — a client that\nmissed it while disconnected recovers it via `GET /sessions/{id}/timeline`.\n\nThe `type` discriminator is **dotted-namespaced** (`run.started`,\n`message.created`), matching the envelope example in docs/05 §3\n(`run.tool.completed`) and the error-code scheme — clients route on this\nstring, so it is load-bearing and every tag is spelled explicitly below.\n\nThis union is intentionally **strict**: there is no `Unknown` catch-all\n(unlike [`crate::content::ContentBlock`], which is open-world because blocks\noriginate from external providers). Every `DomainEvent` is authored by\njarvisd itself, and the web shell is served by the same binary — so producer\nand consumer share one contract version and can never skew. A tag the reader\ndoes not recognize is therefore a genuine bug we want surfaced as a decode\nerror, not silently dropped from a resync page. New variants are added\nadditively within a version (docs/05 §3).",
      "oneOf": [
        {
          "properties": {
            "runId": {
              "$ref": "#/definitions/UlidString"
            },
            "sessionId": {
              "$ref": "#/definitions/UlidString"
            },
            "type": {
              "const": "run.started",
              "type": "string"
            }
          },
          "required": [
            "type",
            "runId",
            "sessionId"
          ],
          "type": "object"
        },
        {
          "properties": {
            "runId": {
              "$ref": "#/definitions/UlidString"
            },
            "state": {
              "$ref": "#/definitions/RunStateDto"
            },
            "type": {
              "const": "run.state_changed",
              "type": "string"
            }
          },
          "required": [
            "type",
            "runId",
            "state"
          ],
          "type": "object"
        },
        {
          "description": "Degraded mode: the run is parked awaiting provider recovery (FR-12) —\na visible waiting state, replayed so a reconnecting client still sees it.",
          "properties": {
            "reason": {
              "type": "string"
            },
            "runId": {
              "$ref": "#/definitions/UlidString"
            },
            "type": {
              "const": "run.queued",
              "type": "string"
            }
          },
          "required": [
            "type",
            "runId",
            "reason"
          ],
          "type": "object"
        },
        {
          "properties": {
            "outcome": {
              "$ref": "#/definitions/RunOutcome"
            },
            "runId": {
              "$ref": "#/definitions/UlidString"
            },
            "type": {
              "const": "run.completed",
              "type": "string"
            }
          },
          "required": [
            "type",
            "runId",
            "outcome"
          ],
          "type": "object"
        },
        {
          "properties": {
            "message": {
              "$ref": "#/definitions/MessageDto"
            },
            "type": {
              "const": "message.created",
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "type": "object"
        },
        {
          "properties": {
            "provider": {
              "$ref": "#/definitions/ProviderDto"
            },
            "type": {
              "const": "provider.health_changed",
              "type": "string"
            }
          },
          "required": [
            "type",
            "provider"
          ],
          "type": "object"
        },
        {
          "description": "Recovery checkpoint (NFR-05/13); replayed so resync reflects the last\nsafe boundary a restart would resume from.",
          "properties": {
            "runId": {
              "$ref": "#/definitions/UlidString"
            },
            "state": {
              "$ref": "#/definitions/RunStateDto"
            },
            "type": {
              "const": "run.checkpoint_saved",
              "type": "string"
            }
          },
          "required": [
            "type",
            "runId",
            "state"
          ],
          "type": "object"
        },
        {
          "description": "An R2/R3 tool proposal is parked awaiting a human decision (F2.5,\ndocs/06 §3). Replayed so a client reconnecting while a run sits at\n`WaitingApproval` still sees the pending card and can act on it.",
          "properties": {
            "card": {
              "$ref": "#/definitions/ApprovalCardDto"
            },
            "type": {
              "const": "approval.requested",
              "type": "string"
            }
          },
          "required": [
            "type",
            "card"
          ],
          "type": "object"
        },
        {
          "description": "A pending approval was answered (F2.5). Replayed so the resolved outcome\nsurvives reconnect and the client can retire the card it was showing.",
          "properties": {
            "approvalId": {
              "$ref": "#/definitions/UlidString"
            },
            "outcome": {
              "$ref": "#/definitions/ApprovalResolutionDto"
            },
            "runId": {
              "$ref": "#/definitions/UlidString"
            },
            "type": {
              "const": "approval.resolved",
              "type": "string"
            }
          },
          "required": [
            "type",
            "approvalId",
            "runId",
            "outcome"
          ],
          "type": "object"
        }
      ]
    },
    "ErrorCode": {
      "oneOf": [
        {
          "enum": [
            "auth.invalid_token",
            "auth.scope_missing",
            "auth.pairing_invalid",
            "validation.failed",
            "idempotency.conflict",
            "resource.version_conflict",
            "resource.not_found",
            "run.budget_exceeded",
            "run.not_cancellable",
            "provider.unavailable",
            "provider.quota_exhausted",
            "policy.denied",
            "grant.expired",
            "grant.args_mismatch",
            "grant.consumed",
            "tool.timeout",
            "tool.result_invalid",
            "artifact.too_large",
            "degraded.queued"
          ],
          "type": "string"
        },
        {
          "const": "artifact.integrity_failed",
          "description": "A stored artifact blob failed content-address verification on read —\non-disk corruption or tampering (F3a.2 CAS verify-on-read). 500; the\nbytes are never returned (fail closed).",
          "type": "string"
        }
      ]
    },
    "EventEnvelope": {
      "properties": {
        "channel": {
          "$ref": "#/definitions/Channel"
        },
        "occurredAt": {
          "description": "RFC 3339 timestamp of the domain occurrence.",
          "type": "string"
        },
        "payload": true,
        "resourceVersion": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "seq": {
          "description": "Monotonic per connection scope; gaps trigger client resync (NFR-13).",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "traceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "description": "Event type discriminator, e.g. `run.tool.completed`.",
          "type": "string"
        },
        "v": {
          "description": "Contract version ([`crate::CONTRACT_VERSION`]).",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "v",
        "seq",
        "channel",
        "type",
        "occurredAt",
        "payload"
      ],
      "type": "object"
    },
    "HealthResponse": {
      "properties": {
        "adapters": {
          "additionalProperties": {
            "$ref": "#/definitions/AdapterHealth"
          },
          "description": "Adapter readiness by adapter name (docs/02 §12 startup order).",
          "type": "object"
        },
        "pairingCode": {
          "description": "One-time pairing code, present only while the first-run pairing\nwindow is open (docs/05 §6: shown on the health page, loopback only).",
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/ServiceStatus"
        },
        "version": {
          "description": "jarvisd semver, for support/diagnostics.",
          "type": "string"
        }
      },
      "required": [
        "status",
        "version",
        "adapters"
      ],
      "type": "object"
    },
    "MessageDto": {
      "properties": {
        "content": {
          "items": {
            "$ref": "#/definitions/ContentBlock"
          },
          "type": "array"
        },
        "createdAt": {
          "description": "RFC 3339.",
          "type": "string"
        },
        "id": {
          "$ref": "#/definitions/UlidString"
        },
        "role": {
          "$ref": "#/definitions/MessageRole"
        },
        "sessionId": {
          "$ref": "#/definitions/UlidString"
        }
      },
      "required": [
        "id",
        "sessionId",
        "role",
        "content",
        "createdAt"
      ],
      "type": "object"
    },
    "MessageRole": {
      "enum": [
        "user",
        "assistant",
        "system"
      ],
      "type": "string"
    },
    "PairRequest": {
      "properties": {
        "deviceName": {
          "type": "string"
        },
        "pairingCode": {
          "type": "string"
        }
      },
      "required": [
        "pairingCode",
        "deviceName"
      ],
      "type": "object"
    },
    "PairResponse": {
      "properties": {
        "deviceId": {
          "$ref": "#/definitions/UlidString"
        },
        "deviceToken": {
          "description": "Opaque 256-bit bearer token; the only time it crosses the wire.",
          "type": "string"
        },
        "scopes": {
          "description": "Device scopes, e.g. `ui`, `display-agent`, `voice-capture` (docs/05 §6).",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "deviceId",
        "deviceToken",
        "scopes"
      ],
      "type": "object"
    },
    "ProblemDetails": {
      "description": "RFC 9457 problem details body plus the stable machine `code` (docs/05 §2).\nThe gateway maps every boundary-crossing error through one `IntoProblem`\nimpl — no inline problem bodies.",
      "properties": {
        "code": {
          "$ref": "#/definitions/ErrorCode"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "instance": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "description": "Problem type URI; `about:blank` when the code says it all.",
          "type": "string"
        }
      },
      "required": [
        "type",
        "title",
        "status",
        "code"
      ],
      "type": "object"
    },
    "ProviderDto": {
      "properties": {
        "id": {
          "description": "Profile id, e.g. `claude-cli` (docs/03 §4).",
          "type": "string"
        },
        "quota": {
          "anyOf": [
            {
              "$ref": "#/definitions/QuotaState"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "description": "Stable reason code only — never raw provider/driver text (docs/06 §5).",
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/definitions/ProviderState"
        }
      },
      "required": [
        "id",
        "state"
      ],
      "type": "object"
    },
    "ProviderState": {
      "oneOf": [
        {
          "enum": [
            "healthy"
          ],
          "type": "string"
        },
        {
          "const": "degraded",
          "description": "Reachable but degraded (e.g. rate-limited); runs may queue.",
          "type": "string"
        },
        {
          "const": "unavailable",
          "description": "Unusable (quota exhausted / auth missing / network down); LLM runs queue.",
          "type": "string"
        }
      ]
    },
    "ProvidersResponse": {
      "properties": {
        "providers": {
          "items": {
            "$ref": "#/definitions/ProviderDto"
          },
          "type": "array"
        }
      },
      "required": [
        "providers"
      ],
      "type": "object"
    },
    "QuotaState": {
      "properties": {
        "resetAt": {
          "description": "RFC 3339 instant the quota/rate window resets, when the provider\nreports one — the user sees *when* service returns (docs/03 §4).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "RiskLevelDto": {
      "description": "Wire projection of [`jarvis_domain::policy::RiskLevel`] (docs/06 §3). An\napproval card only ever carries `R2`/`R3` — `R0`/`R1` auto-authorize and `R4`\nis rejected outright — but the projection is total (no `_`) so a new tier\nforces a decision here rather than silently mapping.",
      "enum": [
        "r0",
        "r1",
        "r2",
        "r3",
        "r4"
      ],
      "type": "string"
    },
    "RunAck": {
      "description": "Acknowledgement returned by `POST /sessions/{id}/messages` (docs/05 §1):\nthe run has been accepted and persisted; streaming follows on the WS.",
      "properties": {
        "runId": {
          "$ref": "#/definitions/UlidString"
        },
        "sessionId": {
          "$ref": "#/definitions/UlidString"
        },
        "state": {
          "$ref": "#/definitions/RunStateDto"
        }
      },
      "required": [
        "runId",
        "sessionId",
        "state"
      ],
      "type": "object"
    },
    "RunBudgetDto": {
      "description": "Per-run resource caps (docs/05 §4, NFR-12). Durations are seconds on the\nwire (JSON has no duration type).",
      "properties": {
        "maxArtifactBytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "maxDurationSecs": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "maxModelTurns": {
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "maxToolCalls": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "maxModelTurns",
        "maxToolCalls",
        "maxDurationSecs",
        "maxArtifactBytes"
      ],
      "type": "object"
    },
    "RunDto": {
      "properties": {
        "budget": {
          "$ref": "#/definitions/RunBudgetDto"
        },
        "createdAt": {
          "description": "RFC 3339.",
          "type": "string"
        },
        "id": {
          "$ref": "#/definitions/UlidString"
        },
        "outcome": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunOutcome"
            },
            {
              "type": "null"
            }
          ],
          "description": "Present only once the run is terminal."
        },
        "sessionId": {
          "$ref": "#/definitions/UlidString"
