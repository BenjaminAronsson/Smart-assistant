            }
          },
          "required": [
            "type",
            "text"
          ],
          "type": "object"
        },
        {
          "description": "Forward-compatibility catch-all (docs/05 §5). Never produced by this\nversion's writers; only ever the result of reading a newer peer.",
          "properties": {
            "type": {
              "const": "unknown",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        }
      ]
